    {
      "name": "Employees",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"department\": \"Engineering\"\n}"
            },
            "url": "http://localhost:8080/api/employees"
          }
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8080/api/employees"
          }
        },
        {
          "name": "Get Employee by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8080/api/employees/1"
          }
        },
        {
          "name": "Get Employee by Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8080/api/employees/email/john.doe@example.com"
          }
        },
        {
          "name": "Get Employees by Department",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8080/api/employees/department/Engineering"
          }
        },
        {
          "name": "Search Employees by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/employees/search?name=John",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "employees", "search"],
              "query": [{"key": "name", "value": "John"}]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"email\": \"john.updated@example.com\",\n  \"department\": \"HR\"\n}"
            },
            "url": "http://localhost:8080/api/employees/1"
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "http://localhost:8080/api/employees/1"
          }
        }
      ]
    },
